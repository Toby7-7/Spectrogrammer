<?xml version="1.0" encoding="utf-8" standalone="no"?>
<manifest xmlns:tools="http://schemas.android.com/tools" xmlns:android="http://schemas.android.com/apk/res/android" package="org.nanoorg.Spectrogrammer">
	<uses-sdk android:minSdkVersion="29"
          android:targetSdkVersion="29" />
    <uses-permission android:name="android.permission.SET_RELEASE_APP"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application android:debuggable="true" android:hasCode="true" android:extractNativeLibs="true" android:label="频谱仪" tools:replace="android:icon,android:theme,android:allowBackup,label" android:icon="@mipmap/icon">
        <service
            android:name=".CaptureForegroundService"
            android:exported="false" />
        <activity android:configChanges="keyboardHidden|orientation" android:label="频谱仪" android:name="android.app.NativeActivity" android:exported="true" android:screenOrientation="portrait" android:theme="@style/SpectrogrammerTheme">
            <meta-data android:name="android.app.lib_name" android:value="Spectrogrammer"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
    </application>
</manifest>
